---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
}

const {
  title = 'Bachs — Payments & Billing for Internet Businesses',
  description = 'The complete billing platform for internet businesses — global checkout, subscription billing, usage-based billing, and settlement to African bank accounts. One integration.',
  canonical = 'https://bachs.io/',
  ogImage = 'https://bachs.io/og-image.png',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Organization schema -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Bachs",
      "legalName": "Bachs, Inc.",
      "url": "https://bachs.io",
      "logo": "https://bachs.io/favicon.png",
      "description": "Bachs is a payments and billing platform for internet businesses selling subscriptions, SaaS, and digital products globally.",
      "foundingDate": "2024",
      "contactPoint": {
        "@type": "ContactPoint",
        "email": "support@bachs.io",
        "contactType": "customer support"
      },
      "sameAs": ["https://x.com/bachshq", "https://docs.bachs.io"]
    }
    </script>

    <!-- WebSite schema -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Bachs",
      "url": "https://bachs.io",
      "description": "Payments and billing infrastructure for internet businesses — global checkout, subscriptions, usage billing, and African settlement.",
      "potentialAction": {
        "@type": "SearchAction",
        "target": {
          "@type": "EntryPoint",
          "urlTemplate": "https://docs.bachs.io/search?q={search_term_string}"
        },
        "query-input": "required name=search_term_string"
      }
    }
    </script>

    <!-- SoftwareApplication schema -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "Bachs",
      "applicationCategory": "BusinessApplication",
      "applicationSubCategory": "PaymentProcessing",
      "operatingSystem": "Web",
      "url": "https://bachs.io",
      "description": "A complete payments and billing platform: global checkout (cards, mobile money, stablecoins), subscription lifecycle management, usage-based billing, automated tax and VAT, and settlement to African bank accounts in NGN, GHS, KES, and ZAR.",
      "featureList": ["Global Checkout","Subscription Billing","Usage-Based Billing","Mobile Money Payments","Stablecoin Checkout (USDT, USDC)","African Bank Settlement (NGN, GHS, KES, ZAR)","Automated VAT/GST","Merchant of Record","Smart Dunning","Plan Entitlements","Node.js SDK","Python SDK","Go SDK","REST API"],
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD",
        "description": "Private beta — apply at bachs.io/early-access"
      },
      "creator": {
        "@type": "Organization",
        "name": "Bachs, Inc.",
        "url": "https://bachs.io"
      }
    }
    </script>

    <!-- Per-page JSON-LD slot (e.g. FAQPage on index) -->
    <slot name="json-ld" />
  </head>
  <body>
    <slot />

    <!-- Scroll reveal — runs after DOM parses, no framework needed -->
    <script>
      const io = new IntersectionObserver(
        (entries) =>
          entries.forEach((e) => {
            if (e.isIntersecting) {
              e.target.classList.add('visible');
              io.unobserve(e.target);
            }
          }),
        { rootMargin: '0px 0px -80px 0px' }
      );
      document.querySelectorAll('.reveal').forEach((el) => io.observe(el));
    </script>
  </body>
</html>
