---
---

<div style="background: #ffffff;">

  <!-- Divider -->
  <div style="max-width: 75rem; margin: 0 auto; padding: 0 1.5rem;"><div style="height: 1px; background: rgba(0,0,0,0.06);"></div></div>

  <!-- Block 1: Global Checkout -->
  <section style="padding: 6rem 0;">
    <div class="checkout-two-col" style="max-width: 75rem; margin: 0 auto; padding: 0 2rem; display: grid; grid-template-columns: 1fr 1fr; gap: 6rem; align-items: center;" id="checkout-grid">
      <!-- Left: copy -->
      <div class="reveal">
        <h2 style="font-family: 'Plus Jakarta Sans', sans-serif; font-size: clamp(1.625rem, 3vw, 2.25rem); font-weight: 600; color: #111111; letter-spacing: -0.02em; line-height: 1.2; margin-bottom: 1.25rem;">One checkout for every customer, everywhere</h2>
        <p style="font-family: 'Inter', sans-serif; font-size: 1rem; font-weight: 400; color: #555555; line-height: 1.7; margin-bottom: 1.5rem;">Cards, mobile money, bank transfer, or stablecoin — one session handles all of them. Bachs detects your customer's location and surfaces the right methods automatically.</p>
        <div style="border-left: 2px solid #e5e5e5; padding-left: 1rem; margin-bottom: 1.75rem;">
          <p style="font-family: 'Inter', sans-serif; font-size: 0.9375rem; font-weight: 400; color: #333333; line-height: 1.65;"><strong style="font-weight: 600;">Accept 150+ currencies</strong> — from EUR and GBP to NGN and KES. Your customer pays in their currency. You receive yours.</p>
        </div>
        <a href="#waitlist" style="font-family: 'Inter', sans-serif; font-size: 0.9375rem; font-weight: 500; color: #111111; text-decoration: none; display: inline-flex; align-items: center; gap: 0.375rem;">
          Explore checkout <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
      <!-- Right: checkout UI mockup -->
      <div class="reveal reveal-delay-2">
        <div style="background: #ffffff; border: 1px solid rgba(0,0,0,0.09); border-radius: 1rem; box-shadow: 0 8px 40px rgba(0,0,0,0.07); overflow: hidden;">
          <div style="padding: 1.5rem 1.5rem 0.5rem; border-bottom: 1px solid rgba(0,0,0,0.06);">
            <div style="font-family: 'Inter', sans-serif; font-size: 0.9375rem; font-weight: 600; color: #111111; margin-bottom: 0.25rem;">Complete your order</div>
            <div style="font-family: 'Inter', sans-serif; font-size: 0.8125rem; color: #888888;">BuilderKit Pro · $49.00 / month</div>
          </div>
          <div style="padding: 1.25rem 1.5rem; display: flex; flex-direction: column; gap: 0.625rem;">
            <!-- Email row -->
            <div style="display: grid; grid-template-columns: 5rem 1fr; align-items: center; padding: 0.875rem 1rem; border: 1px solid rgba(0,0,0,0.08); border-radius: 0.5rem;">
              <span style="font-family: 'Inter', sans-serif; font-size: 0.8125rem; color: #aaaaaa;">Email</span>
              <span style="font-family: 'Inter', sans-serif; font-size: 0.8125rem; color: #333333;">tunde@buildkit.co</span>
            </div>
            <!-- Payment method -->
            <div style="display: grid; grid-template-columns: 5rem 1fr; align-items: center; padding: 0.875rem 1rem; border: 1px solid rgba(0,0,0,0.08); border-radius: 0.5rem;">
              <span style="font-family: 'Inter', sans-serif; font-size: 0.8125rem; color: #aaaaaa;">Pay with</span>
              <div style="display: flex; align-items: center; gap: 0.5rem;">
                <div style="background: #1a1a2e; border-radius: 3px; padding: 2px 6px; font-size: 0.6rem; font-weight: 700; color: #fff; letter-spacing: 0.05em;">VISA</div>
                <span style="font-family: 'Inter', sans-serif; font-size: 0.8125rem; color: #333333;">•••• 4242</span>
                <svg style="margin-left: auto;" width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M4 6l4 4 4-4" stroke="#aaa" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </div>
            </div>
            <!-- Settlement -->
            <div style="display: grid; grid-template-columns: 5rem 1fr; align-items: center; padding: 0.875rem 1rem; border: 1px solid rgba(0,0,0,0.08); border-radius: 0.5rem;">
              <span style="font-family: 'Inter', sans-serif; font-size: 0.8125rem; color: #aaaaaa;">Settle to</span>
              <span style="font-family: 'Inter', sans-serif; font-size: 0.8125rem; color: #333333;">NGN · GTBank ••4581</span>
            </div>
            <!-- VAT note -->
            <div style="display: flex; align-items: center; justify-content: space-between; padding: 0.5rem 0.25rem;">
              <div style="display: flex; align-items: center; gap: 0.375rem; font-family: 'Inter', sans-serif; font-size: 0.75rem; color: #111111;">
                <svg width="12" height="12" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.5"/><path d="M5 8l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                VAT calculated · UK 20%
              </div>
              <span style="font-family: 'Inter', sans-serif; font-size: 0.75rem; color: #aaaaaa;">+ $9.80</span>
            </div>
            <!-- Pay button -->
            <button style="width: 100%; height: 3rem; background: #111111; color: #ffffff; border: none; border-radius: 9999px; font-family: 'Inter', sans-serif; font-size: 0.9375rem; font-weight: 500; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 0.5rem; margin-top: 0.25rem;">
              Pay $58.80
              <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><rect x="2" y="5" width="12" height="8" rx="1.5" stroke="currentColor" stroke-width="1.5"/><path d="M5 5V4a3 3 0 0 1 6 0v1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
            </button>
            <div style="text-align: center; font-family: 'Inter', sans-serif; font-size: 0.75rem; color: #aaaaaa; padding-bottom: 0.25rem;">Secured by Bachs · VAT handled automatically</div>
          </div>
        </div>
      </div>
    </div>
  </section>

</div>
