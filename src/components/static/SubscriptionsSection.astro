---
---

<section style="padding: 6rem 1.5rem; background: #ffffff;">
  <div class="subs-grid" style="max-width: 75rem; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 6rem; align-items: center;">
    <!-- Left: UI mockup -->
    <div class="reveal">
      <div style="background: #ffffff; border: 1px solid rgba(0,0,0,0.09); border-radius: 1rem; box-shadow: 0 8px 40px rgba(0,0,0,0.07); overflow: hidden; padding: 1.5rem;">
        <div style="font-family: 'Inter', sans-serif; font-size: 0.9375rem; font-weight: 600; color: #111111; margin-bottom: 1.25rem;">Subscription overview</div>
        <!-- Plan cards -->
        <div style="display: flex; flex-direction: column; gap: 0.625rem; margin-bottom: 1.25rem;">
          <div style="display: flex; justify-content: space-between; align-items: center; padding: 0.875rem 1rem; border: 1.5px solid #111111; border-radius: 0.625rem; background: #fafafa;">
            <div>
              <div style="font-family: 'Inter', sans-serif; font-size: 0.875rem; font-weight: 600; color: #111111;">Pro</div>
              <div style="font-family: 'Inter', sans-serif; font-size: 0.75rem; color: #888888; margin-top: 0.125rem;">47 active · 3 trialling</div>
            </div>
            <div style="text-align: right;">
              <div style="font-family: 'Inter', sans-serif; font-size: 1rem; font-weight: 600; color: #111111;">$49<span style="font-size: 0.75rem; font-weight: 400; color: #888888;">/mo</span></div>
              <div style="font-family: 'Inter', sans-serif; font-size: 0.7rem; color: #555555; margin-top: 0.125rem;">&#8593; 12% MoM</div>
            </div>
          </div>
          <div style="display: flex; justify-content: space-between; align-items: center; padding: 0.875rem 1rem; border: 1px solid rgba(0,0,0,0.08); border-radius: 0.625rem;">
            <div>
              <div style="font-family: 'Inter', sans-serif; font-size: 0.875rem; font-weight: 500; color: #333333;">Starter</div>
              <div style="font-family: 'Inter', sans-serif; font-size: 0.75rem; color: #888888; margin-top: 0.125rem;">112 active</div>
            </div>
            <div style="text-align: right;">
              <div style="font-family: 'Inter', sans-serif; font-size: 1rem; font-weight: 600; color: #333333;">$19<span style="font-size: 0.75rem; font-weight: 400; color: #888888;">/mo</span></div>
            </div>
          </div>
          <div style="display: flex; justify-content: space-between; align-items: center; padding: 0.875rem 1rem; border: 1px solid rgba(0,0,0,0.08); border-radius: 0.625rem;">
            <div>
              <div style="font-family: 'Inter', sans-serif; font-size: 0.875rem; font-weight: 500; color: #333333;">Enterprise</div>
              <div style="font-family: 'Inter', sans-serif; font-size: 0.75rem; color: #888888; margin-top: 0.125rem;">8 active · custom pricing</div>
            </div>
            <div style="text-align: right;">
              <div style="font-family: 'Inter', sans-serif; font-size: 1rem; font-weight: 600; color: #333333;">Custom</div>
            </div>
          </div>
        </div>
        <!-- MRR stat -->
        <div style="display: flex; align-items: center; justify-content: space-between; padding: 0.875rem 1rem; background: #f4f5f9; border-radius: 0.625rem;">
          <span style="font-family: 'Inter', sans-serif; font-size: 0.8125rem; color: #555555;">Total MRR</span>
          <span style="font-family: 'Inter', sans-serif; font-size: 1rem; font-weight: 700; color: #111111;">$4,411 <span style="font-size: 0.75rem; font-weight: 400; color: #555555;">&#8593; 8.3%</span></span>
        </div>
      </div>
    </div>
    <!-- Right: copy -->
    <div class="reveal reveal-delay-2">
      <h2 style="font-family: 'Plus Jakarta Sans', sans-serif; font-size: clamp(1.625rem, 3vw, 2.25rem); font-weight: 600; color: #111111; letter-spacing: -0.02em; line-height: 1.2; margin-bottom: 1.25rem;">Subscriptions that run themselves</h2>
      <p style="font-family: 'Inter', sans-serif; font-size: 1rem; font-weight: 400; color: #555555; line-height: 1.7; margin-bottom: 1.5rem;">Full subscription lifecycle out of the box — free trials, upgrades, downgrades, pauses, cancellations, and automatic proration. No custom logic required.</p>
      <div style="border-left: 2px solid #e5e5e5; padding-left: 1rem; margin-bottom: 1.75rem;">
        <p style="font-family: 'Inter', sans-serif; font-size: 0.9375rem; font-weight: 400; color: #333333; line-height: 1.65;">Use <strong style="font-weight: 600;">usage billing</strong> to meter by API calls, tokens, seats, or any unit you define. We aggregate, rate, and invoice automatically.</p>
      </div>
      <a href="#waitlist" style="font-family: 'Inter', sans-serif; font-size: 0.9375rem; font-weight: 500; color: #111111; text-decoration: none; display: inline-flex; align-items: center; gap: 0.375rem;">
        Explore billing <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    </div>
  </div>
</section>
