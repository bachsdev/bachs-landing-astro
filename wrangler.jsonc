{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "bachs-landing",
  "compatibility_date": "2026-05-12",
  "compatibility_flags": ["nodejs_compat"],
  "main": "./worker.js",
  "assets": {
    "binding": "ASSETS",
    "directory": "dist",
    "serve_directly": false
  },
  "observability": {
    "enabled": true
  }
}
